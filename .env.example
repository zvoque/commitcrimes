# Optional in dev (unauthenticated GitHub = 60 req/hr).
# REQUIRED in production: a GitHub token lifts the limit to 5,000 req/hr.
# Create a fine-grained or classic token with NO scopes (public data only):
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Clerk auth (optional: powers the Deep Record / private-repo feature) ---
# Leave blank to disable; /deep shows a "not configured" notice and the rest
# of the app is unaffected. Create a Clerk app, add GitHub as a social
# connection with base scope `read:user` (Deep Record steps up to `repo` only
# when the user opts in to private analysis). See SPEC.md §12.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Database (optional: cache + fresh badges + Most Wanted leaderboard) ---
# Neon Postgres connection string (HTTP/pooled). Without it, the store no-ops
# and the app still works (badges recompute statelessly). See SPEC.md §13.
# After setting it: `pnpm db:push` to create the table.
DATABASE_URL=

# PostHog (publishable client key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
